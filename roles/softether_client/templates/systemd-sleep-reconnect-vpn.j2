#!/bin/sh
# Managed by Ansible (softether_client role) — do not edit by hand.
# Trigger reconnect-vpn.service after resume from sleep/hibernate.
# Called by systemd-sleep with $1=pre|post and $2=suspend|hibernate|hybrid-sleep|...
case "$1" in
    post)
        systemctl start --no-block reconnect-vpn.service
        ;;
esac
