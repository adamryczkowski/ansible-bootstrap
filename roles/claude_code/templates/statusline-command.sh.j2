#!/usr/bin/env bash
# Claude Code status line script — managed by Ansible (claude_code role)

input=$(cat)

cwd=$(echo "$input" | jq -r '.workspace.current_dir // .cwd // empty')
used_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty')
five_hour_pct=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // empty')
five_hour_resets_at=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // empty')
seven_day_pct=$(echo "$input" | jq -r '.rate_limits.seven_day.used_percentage // empty')
seven_day_resets_at=$(echo "$input" | jq -r '.rate_limits.seven_day.resets_at // empty')
# "sonnet" limit: Claude Max tracks a per-model (Sonnet) usage window separately.
sonnet_pct=$(echo "$input" | jq -r '
  .rate_limits
  | to_entries[]
  | select(.key | test("sonnet"; "i"))
  | .value.used_percentage
  // empty' 2>/dev/null | head -1)

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
ORANGE='\033[38;5;208m'
RESET='\033[0m'

# Fetch account email using the OAuth access token
creds_file="{{ claude_code_user_home }}/.claude/.credentials.json"
email_cache="{{ claude_code_user_home }}/.claude/.account_email_cache"
account=""
if [ -f "$creds_file" ]; then
    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
    if [ -n "$token" ]; then
        # Use cached email if cache is fresh (less than 3600 seconds old)
        if [ -f "$email_cache" ]; then
            cache_age=$(( $(date +%s) - $(stat -c %Y "$email_cache" 2>/dev/null || echo 0) ))
            if [ "$cache_age" -lt 3600 ]; then
                account=$(cat "$email_cache" 2>/dev/null)
            fi
        fi
        # Refresh cache if empty or stale
        if [ -z "$account" ]; then
            fetched=$(curl -sf --max-time 3 \
                -H "Authorization: Bearer $token" \
                -H "anthropic-client-type: claude-code" \
                "https://api.claude.ai/api/auth/current_account" 2>/dev/null \
                | jq -r '.email_address // .email // empty' 2>/dev/null)
            if [ -n "$fetched" ]; then
                account="$fetched"
                printf '%s' "$fetched" > "$email_cache"
            fi
        fi
    fi
fi

# Build status line parts
parts=()

# 0. Per-account overlay slug (set by bubblewrap wrapper in claude_accounts.sh)
if [ -n "$CLAUDE_ACCOUNT" ]; then
    case "$CLAUDE_ACCOUNT" in
        sofia) acct_color="$GREEN" ;;
        adam)  acct_color="$RED" ;;
        mik)   acct_color="$ORANGE" ;;
        *)     acct_color="$RESET" ;;
    esac
    parts+=("$(printf "${acct_color}%s${RESET}" "$CLAUDE_ACCOUNT")")
fi

# 1. Logged-in account (email/username)
if [ -n "$account" ]; then
    parts+=("$account")
fi

# 2. Context window usage (green <20%, red >88%, orange otherwise)
if [ -n "$used_pct" ]; then
    ctx_band=$(awk -v p="$used_pct" 'BEGIN {
        if (p < 20) print "green"
        else if (p > 88) print "red"
        else print "orange"
    }')
    case "$ctx_band" in
        green) _cc="$GREEN" ;;
        red)   _cc="$RED" ;;
        *)     _cc="$ORANGE" ;;
    esac
    parts+=("$(printf "${_cc}ctx:%.0f%%${RESET}" "$used_pct")")
fi

# 3. Claude Max allowances: 5h, 7d, and Sonnet model limits
limits=""
if [ -n "$five_hour_pct" ]; then
    # --- "ends ..." time remaining in the 5h window ---
    five_time_str=""
    if [ -n "$five_hour_resets_at" ]; then
        now=$(date +%s)
        five_secs_left=$(( five_hour_resets_at - now ))
        if [ "$five_secs_left" -le 0 ]; then
            five_time_str="0m"
        else
            five_h_left=$(( five_secs_left / 3600 ))
            five_m_left=$(( (five_secs_left % 3600) / 60 ))
            if [ "$five_h_left" -gt 0 ]; then
                five_time_str="${five_h_left}h${five_m_left}m"
            else
                five_time_str="${five_m_left}m"
            fi
        fi
    fi

    # --- Color logic ---
    # Burning C% of the 5h budget at 100%/hr takes C/100 hours. If the 5h
    # window resets mid-burn (in tr_h hours), only 100*tr_h is charged to
    # the current bucket; the rest lands in a fresh bucket.
    # Constraints after consuming C%:
    #     5h:     fh + min(C, 100*tr_h) <= 100
    #     weekly: 7*wk + C <= 700    (weekly = 7 × 5h, short burn ≪ 7d)
    # Green at C=60, yellow at C=20. If reset time unknown, assume no
    # imminent reset (large tr_h → min collapses to C, strict 5h cap).
    five_color=$(awk \
        -v fp="$five_hour_pct" \
        -v sp="${seven_day_pct:-0}" \
        -v tr="${five_secs_left:-86400}" \
        'BEGIN {
            tr_h = tr / 3600
            c = 60
            h5 = (c < 100*tr_h) ? c : 100*tr_h
            green_ok = (fp + h5 <= 100) && (7*sp + c <= 700)
            c = 20
            h5 = (c < 100*tr_h) ? c : 100*tr_h
            yellow_ok = (fp + h5 <= 100) && (7*sp + c <= 700)
            if (green_ok) { print "green" }
            else if (yellow_ok) { print "yellow" }
            else { print "red" }
        }')
    case "$five_color" in
        green)  _fc="$GREEN" ;;
        yellow) _fc="$YELLOW" ;;
        *)      _fc="$RED" ;;
    esac

    if [ -n "$five_time_str" ]; then
        limits="$(printf "${_fc}5h:$(printf '%.0f' "$five_hour_pct")%% (ends %s)${RESET}" "$five_time_str")"
    else
        limits="$(printf "${_fc}5h:$(printf '%.0f' "$five_hour_pct")%%${RESET}")"
    fi
fi
if [ -n "$sonnet_pct" ]; then
    [ -n "$limits" ] && limits="$limits " || true
    limits="${limits}son:$(printf '%.0f' "$sonnet_pct")%"
fi
if [ -n "$limits" ]; then
    parts+=("$limits")
fi

# 4. Weekly window: usage% + surplus/deficit vs working-hours pace.
#    Expected usage accumulates only during 08:00-21:00 local time.
#    Nights (21:00-08:00) are dead: "spare" stays flat if you don't work.
#    A full 7-day span always contains exactly 7*13 = 91 active hours.
#    metric = expected_pct - seven_day_used_pct
#    Positive (green): under pace — that much budget "spare" right now.
#    Negative (red): over pace — in deficit.
if [ -n "$seven_day_pct" ] && [ -n "$seven_day_resets_at" ]; then
    now=$(date +%s)
    secs_left=$(( seven_day_resets_at - now ))
    week_secs=604800
    w_start=$(( seven_day_resets_at - week_secs ))
    active_total=$(( 7 * 13 * 3600 ))
    # Clamp now into [w_start, resets_at] to tolerate stale/future data.
    eff_now="$now"
    [ "$eff_now" -gt "$seven_day_resets_at" ] && eff_now="$seven_day_resets_at"
    [ "$eff_now" -lt "$w_start" ] && eff_now="$w_start"
    # Walk calendar days in [w_start, eff_now], summing overlap of each
    # day's [08:00, 21:00) slice with the clamped window.
    active_elapsed=0
    d=$(date -d "@$w_start" +%Y-%m-%d 2>/dev/null)
    end_d=$(date -d "@$eff_now" +%Y-%m-%d 2>/dev/null)
    if [ -n "$d" ] && [ -n "$end_d" ]; then
        while :; do
            day_8=$(date -d "$d 08:00" +%s 2>/dev/null)
            day_21=$(date -d "$d 21:00" +%s 2>/dev/null)
            if [ -z "$day_8" ] || [ -z "$day_21" ]; then
                break
            fi
            lo=$(( day_8 > w_start ? day_8 : w_start ))
            hi=$(( day_21 < eff_now ? day_21 : eff_now ))
            if [ "$hi" -gt "$lo" ]; then
                active_elapsed=$(( active_elapsed + hi - lo ))
            fi
            [ "$d" = "$end_d" ] && break
            d=$(date -d "$d + 1 day" +%Y-%m-%d 2>/dev/null)
            [ -z "$d" ] && break
        done
    fi
    metric=$(awk -v ae="$active_elapsed" -v at="$active_total" -v used="$seven_day_pct" \
        'BEGIN { printf "%.1f", (ae/at)*100 - used }')
    if [ "$secs_left" -le 0 ]; then
        time_left="0d"
    else
        days_left=$(( secs_left / 86400 ))
        hours_left=$(( (secs_left % 86400) / 3600 ))
        if [ "$days_left" -gt 0 ]; then
            time_left="${days_left}d${hours_left}h"
        else
            time_left="${hours_left}h"
        fi
    fi
    is_negative=$(awk -v m="$metric" 'BEGIN { print (m < 0) ? "1" : "0" }')
    if [ "$is_negative" = "1" ]; then
        metric_color="$RED"
    else
        metric_color="$GREEN"
    fi
    # Window-reset proximity: red if reset lands today, yellow tomorrow, green later.
    reset_date=$(date -d "@$seven_day_resets_at" +%Y-%m-%d 2>/dev/null)
    today_date=$(date +%Y-%m-%d)
    tomorrow_date=$(date -d "tomorrow" +%Y-%m-%d 2>/dev/null)
    if [ -n "$reset_date" ] && [ "$reset_date" = "$today_date" ]; then
        reset_color="$RED"
    elif [ -n "$reset_date" ] && [ "$reset_date" = "$tomorrow_date" ]; then
        reset_color="$YELLOW"
    else
        reset_color="$GREEN"
    fi
    parts+=("$(printf "${reset_color}7d:%.0f%% (ends %s)${RESET}" "$seven_day_pct" "$time_left")")
    parts+=("$(printf "${metric_color}spare %+.1f%%${RESET}" "$metric")")
elif [ -n "$seven_day_pct" ]; then
    parts+=("7d:$(printf '%.0f' "$seven_day_pct")%")
fi

# 5. claude-hierarchy MCP server availability
if command -v claude-hierarchy >/dev/null 2>&1; then
    # Read version from npm metadata — calling `claude-hierarchy --version`
    # starts the MCP server on stdio instead of printing a version string.
    ch_version=$(timeout 2 npm list -g --depth=0 claude-hierarchy 2>/dev/null \
        | grep -oP 'claude-hierarchy@\K[^ ]+' | head -1)
    if [ -n "$ch_version" ]; then
        parts+=("$(printf "${GREEN}claude-hierarchy: %s${RESET}" "$ch_version")")
    else
        parts+=("$(printf "${GREEN}claude-hierarchy${RESET}")")
    fi
else
    parts+=("$(printf "${RED}no claude-hierarchy${RESET}")")
fi

# 6. Current folder (home-relative path, e.g. ~/tmp/ansible-bootstrap)
if [ -n "$cwd" ]; then
    if [ -n "$HOME" ] && [ "$cwd" = "$HOME" ]; then
        parts+=("~")
    elif [ -n "$HOME" ] && [ "${cwd#$HOME/}" != "$cwd" ]; then
        parts+=("~/${cwd#$HOME/}")
    else
        parts+=("$cwd")
    fi
fi

# Join with separator
status=""
for part in "${parts[@]}"; do
    if [ -z "$status" ]; then
        status="$part"
    else
        status="$status | $part"
    fi
done

printf '%s' "$status"
