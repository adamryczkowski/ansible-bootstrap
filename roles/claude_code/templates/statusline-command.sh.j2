#!/usr/bin/env bash
# Claude Code status line script — managed by Ansible (claude_code role)

input=$(cat)

cwd=$(echo "$input" | jq -r '.workspace.current_dir // .cwd // empty')
used_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty')
five_hour_pct=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // empty')
seven_day_pct=$(echo "$input" | jq -r '.rate_limits.seven_day.used_percentage // empty')
# "sonnet" limit: Claude Max tracks a per-model (Sonnet) usage window separately.
sonnet_pct=$(echo "$input" | jq -r '
  .rate_limits
  | to_entries[]
  | select(.key | test("sonnet"; "i"))
  | .value.used_percentage
  // empty' 2>/dev/null | head -1)

# Fetch account email using the OAuth access token
creds_file="{{ claude_code_user_home }}/.claude/.credentials.json"
email_cache="{{ claude_code_user_home }}/.claude/.account_email_cache"
account=""
if [ -f "$creds_file" ]; then
    token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
    if [ -n "$token" ]; then
        # Use cached email if cache is fresh (less than 3600 seconds old)
        if [ -f "$email_cache" ]; then
            cache_age=$(( $(date +%s) - $(stat -c %Y "$email_cache" 2>/dev/null || echo 0) ))
            if [ "$cache_age" -lt 3600 ]; then
                account=$(cat "$email_cache" 2>/dev/null)
            fi
        fi
        # Refresh cache if empty or stale
        if [ -z "$account" ]; then
            fetched=$(curl -sf --max-time 3 \
                -H "Authorization: Bearer $token" \
                -H "anthropic-client-type: claude-code" \
                "https://api.claude.ai/api/auth/current_account" 2>/dev/null \
                | jq -r '.email_address // .email // empty' 2>/dev/null)
            if [ -n "$fetched" ]; then
                account="$fetched"
                printf '%s' "$fetched" > "$email_cache"
            fi
        fi
    fi
fi

# Build status line parts
parts=()

# 1. Logged-in account (email/username)
if [ -n "$account" ]; then
    parts+=("$account")
fi

# 2. Context window usage
if [ -n "$used_pct" ]; then
    parts+=("ctx:$(printf '%.0f' "$used_pct")%")
fi

# 3. Claude Max allowances: 5h, 7d, and Sonnet model limits
limits=""
if [ -n "$five_hour_pct" ]; then
    limits="5h:$(printf '%.0f' "$five_hour_pct")%"
fi
if [ -n "$seven_day_pct" ]; then
    [ -n "$limits" ] && limits="$limits " || true
    limits="${limits}7d:$(printf '%.0f' "$seven_day_pct")%"
fi
if [ -n "$sonnet_pct" ]; then
    [ -n "$limits" ] && limits="$limits " || true
    limits="${limits}son:$(printf '%.0f' "$sonnet_pct")%"
fi
if [ -n "$limits" ]; then
    parts+=("$limits")
fi

# 4. claude-hierarchy MCP server availability
GREEN='\033[0;32m'
RED='\033[0;31m'
RESET='\033[0m'
if command -v claude-hierarchy >/dev/null 2>&1; then
    # Read version from npm metadata — calling `claude-hierarchy --version`
    # starts the MCP server on stdio instead of printing a version string.
    ch_version=$(timeout 2 npm list -g --depth=0 claude-hierarchy 2>/dev/null \
        | grep -oP 'claude-hierarchy@\K[^ ]+' | head -1)
    if [ -n "$ch_version" ]; then
        parts+=("$(printf "${GREEN}claude-hierarchy: %s${RESET}" "$ch_version")")
    else
        parts+=("$(printf "${GREEN}claude-hierarchy${RESET}")")
    fi
else
    parts+=("$(printf "${RED}no claude-hierarchy${RESET}")")
fi

# 5. Current folder
if [ -n "$cwd" ]; then
    parts+=("$(basename "$cwd")")
fi

# Join with separator
status=""
for part in "${parts[@]}"; do
    if [ -z "$status" ]; then
        status="$part"
    else
        status="$status | $part"
    fi
done

printf '%s' "$status"
