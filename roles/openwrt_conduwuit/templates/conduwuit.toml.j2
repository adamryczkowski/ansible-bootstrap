# {{ ansible_managed }}
# conduwuit Matrix homeserver configuration for OpenWRT
# Deployed by the openwrt_conduwuit Ansible role.

[global]
server_name = "{{ openwrt_conduwuit_server_name }}"
database_path = "/var/lib/conduwuit"
port = {{ openwrt_conduwuit_port }}
address = ["{{ openwrt_conduwuit_address }}"]
max_request_size = {{ openwrt_conduwuit_max_request_size }}
log = "{{ openwrt_conduwuit_log }}"
allow_registration = {{ openwrt_conduwuit_allow_registration | lower }}
{% if openwrt_conduwuit_registration_token is defined and openwrt_conduwuit_registration_token %}
registration_token = "{{ openwrt_conduwuit_registration_token }}"
{% endif %}
allow_federation = {{ openwrt_conduwuit_allow_federation | lower }}
trusted_servers = {{ openwrt_conduwuit_trusted_servers | to_json }}
allow_encryption = true
allow_room_creation = true

[global.well_known]
client = "{{ openwrt_conduwuit_well_known_client }}"
server = "{{ openwrt_conduwuit_well_known_server }}"
