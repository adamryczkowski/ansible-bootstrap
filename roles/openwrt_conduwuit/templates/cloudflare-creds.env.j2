# {{ ansible_managed }}
# Cloudflare API credentials for acme.sh dns_cf DNS-01 challenge plugin.
# Sourced as shell environment variables by the acme-acmesh init script.
# This file is mode 0600 — contains sensitive API token material.
#
# CF_Token: API token with Zone:DNS:Edit permission for the target zone.
# CF_Zone_ID: Zone ID (optional but avoids zone auto-detection on each run).
CF_Token="{{ openwrt_conduwuit_cloudflare_api_token }}"
CF_Zone_ID="{{ openwrt_conduwuit_cloudflare_zone_id }}"
